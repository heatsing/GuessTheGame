# ---------------------------------------------------------------------------
# Guess the Game — environment variable template
# ---------------------------------------------------------------------------
# Copy to `.env.local` for local development, and set the same variables in the
# Vercel project settings (and GitHub Actions secrets where noted). This file
# contains ONLY public, non-secret values — no tokens, keys, or credentials.
# Secret values (VERCEL_TOKEN, etc.) live in GitHub Secrets / Vercel env vars
# and are NEVER committed. See docs/deployment.md.
# ---------------------------------------------------------------------------

# Public site URL. Used to build canonical URLs, Open Graph tags, sitemap, and
# robots.txt. In production this MUST be set to the real domain. When unset,
# the app falls back to a placeholder (https://guess-the-game.example.com) so
# local builds still work — see src/lib/site-config.ts.
# Local dev:  http://localhost:3000  (or leave unset for the placeholder)
# Preview:     https://<preview-slug>.vercel.app
# Production:  https://your-real-domain.com
NEXT_PUBLIC_SITE_URL=https://guess-the-game.example.com

# ---------------------------------------------------------------------------
# Build flag (internal, not user-facing). Set by scripts/build.mjs when
# retrying a failed static export on Windows. Do NOT set manually in CI/prod.
# GTG_SKIP_EXPORT=true
# ---------------------------------------------------------------------------
